# Railway provides DATABASE_URL automatically when you attach a Postgres service.
# For local dev, leave blank to use SQLite at ./data/specialsits.db
DATABASE_URL=

# Gemini API key — same one used by PromoWatch is fine
GEMINI_API_KEY=

# Shared secret between the Apps Script email intake and this API
INGEST_TOKEN=change-me-to-a-long-random-string

# Admin password for the /admin page
ADMIN_PASSWORD=change-me

# Public site URL (used in CORS)
PUBLIC_URL=*

PORT=3000
